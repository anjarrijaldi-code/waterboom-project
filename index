};

var NAMA_HARI = ["Minggu","Senin","Selasa","Rabu","Kamis","Jumat","Sabtu"];

function getDateInfo(ds) {
  if (!ds) return null;
  var parts = ds.split("-");
  var y = parseInt(parts[0]), m = parseInt(parts[1])-1, d = parseInt(parts[2]);
  var dt = new Date(y, m, d);
  var dow = dt.getDay();
  var isHoliday = HARI_LIBUR.has(ds);
  var isWeekend = (dow === 0 || dow === 6);
  var isFriday = (dow === 5);
  var namaHoliday = NAMA_LIBUR[ds] || null;
  var namaHari = NAMA_HARI[dow];
  var type, price, icon, label, desc, badgeClass;
  if (isHoliday) {
    type = "libur"; price = 20000; icon = "🎊";
    label = namaHari + " — HARI LIBUR NASIONAL";
    desc = namaHoliday || "Hari Libur Nasional";
    badgeClass = "badge-libur";
  } else if (isWeekend) {
    type = "weekend"; price = 20000; icon = "🎉";
    label = namaHari + " — WEEKEND";
    desc = "Sabtu & Minggu harga weekend berlaku";
    badgeClass = "badge-weekend";
  } else {
    type = "weekday"; price = 15000; icon = "☀️";
    label = namaHari + " — WEEKDAY";
    desc = isFriday ? "Buka mulai jam 13.00 – 17.00 WIB" : "Senin–Jumat harga weekday berlaku";
    badgeClass = "badge-weekday";
  }
  var tglFmt = dt.toLocaleDateString("id-ID", {weekday:"long",day:"numeric",month:"long",year:"numeric"});
  return {type:type, price:price, icon:icon, label:label, desc:desc,
          badgeClass:badgeClass, namaHoliday:namaHoliday, isFriday:isFriday, tglFmt:tglFmt};
}

var state = {price:0, qty:1, type:"", tglFmt:"", dateStr:""};

function onDateChange() {
  var ds = document.getElementById("visitDate").value;
  if (!ds) return;
  var info = getDateInfo(ds);
  state.price = info.price;
  state.type = info.type;
  state.tglFmt = info.tglFmt;
  state.dateStr = ds;

  var box = document.getElementById("dateResultBox");
  box.className = "date-result-box " + info.type;
  document.getElementById("drbIcon").textContent = info.icon;
  document.getElementById("drbType").textContent = info.label;
  document.getElementById("drbDesc").textContent = info.desc;

  var pb = document.getElementById("drbPriceBox");
  pb.style.display = "block";
  var am = document.getElementById("drbAmount");
  am.textContent = "Rp " + info.price.toLocaleString("id-ID");
  am.className = "amount " + info.type;

  var eb = box.querySelector(".drb-badge");
  if (eb) eb.remove();
  var bg = document.createElement("div");
  bg.className = "drb-badge " + info.badgeClass;
  bg.textContent = info.type === "libur" ? "🔴 LIBUR NASIONAL" : info.type === "weekend" ? "🟡 WEEKEND" : "🟢 WEEKDAY";
  box.appendChild(bg);

  var ne = document.getElementById("holidayNote");
  if (info.isFriday) {
    ne.textContent = "⏰ Hari Jumat buka mulai jam 13.00 – 17.00 WIB";
    ne.style.color = "#0277BD";
  } else if (info.namaHoliday) {
    ne.textContent = "🎊 " + info.namaHoliday + " — Harga weekend berlaku";
    ne.style.color = "#BF360C";
  } else {
    ne.textContent = "";
  }

  var jamSel = document.getElementById("jamMasuk");
  var allJam = ["08.00 WIB","09.00 WIB","10.00 WIB","11.00 WIB","12.00 WIB","13.00 WIB","14.00 WIB","15.00 WIB"];
  var friJam = ["13.00 WIB","14.00 WIB","15.00 WIB"];
  var pv = jamSel.value;
  jamSel.innerHTML = "<option value=''>-- Pilih Jam --</option>";
  var opts = info.isFriday ? friJam : allJam;
  for (var i = 0; i < opts.length; i++) {
    var o = document.createElement("option");
    o.value = opts[i]; o.textContent = opts[i];
    if (opts[i] === pv) o.selected = true;
    jamSel.appendChild(o);
  }
  updateSummary();
}

function changeQty(d) {
  state.qty = Math.max(1, Math.min(100, state.qty + d));
  document.getElementById("qtyVal").textContent = state.qty;
  updateSummary();
}

function fmt(n) {
  return "Rp " + n.toLocaleString("id-ID");
}

function updateSummary() {
  var jam = document.getElementById("jamMasuk").value;
  var nama = document.getElementById("namaLengkap").value.trim();
  var kota = document.getElementById("kota").value.trim();
  var pay = document.getElementById("payMethod").value;
  var tLabel = state.type === "libur" ? "Hari Libur Nasional" :
               state.type === "weekend" ? "Weekend / Sabtu-Minggu" :
               state.type === "weekday" ? "Weekday / Senin-Jumat" : "—";
  document.getElementById("sumHargaRow").className = "sum-row highlight-price " + (state.type || "");
  document.getElementById("sumTicket").textContent = tLabel;
  document.getElementById("sumPrice").textContent = state.price ? fmt(state.price) : "—";
  document.getElementById("sumQty").textContent = state.qty + " orang";
  document.getElementById("sumDate").textContent = state.tglFmt || "—";
  document.getElementById("sumJam").textContent = jam || "—";
  document.getElementById("sumNama").textContent = nama || "—";
  document.getElementById("sumKota").textContent = kota || "—";
  document.getElementById("sumPay").textContent = pay || "—";
  document.getElementById("sumTotal").textContent = state.price ? fmt(state.price * state.qty) : "—";
}

function doBooking() {
  var ds = document.getElementById("visitDate").value;
  var jam = document.getElementById("jamMasuk").value;
  var nama = document.getElementById("namaLengkap").value.trim();
  var hp = document.getElementById("nohp").value.trim();
  var pay = document.getElementById("payMethod").value;
  if (!ds) { alert("Silakan pilih tanggal kunjungan."); return; }
  if (!jam) { alert("Silakan pilih jam masuk."); return; }
  if (!nama) { alert("Silakan masukkan nama lengkap."); return; }
  if (!hp) { alert("Silakan masukkan nomor HP/WhatsApp."); return; }
  if (!pay) { alert("Silakan pilih metode pembayaran."); return; }
  var code = "WBS-" + Date.now().toString(36).toUpperCase().slice(-6);
  document.getElementById("bookCode").textContent = code;
  var total = state.price * state.qty;
  var info = getDateInfo(ds);
  var tLabel = state.type === "libur" ? "Libur Nasional" : state.type === "weekend" ? "Weekend" : "Weekday";
  var detail = "<strong>Nama:</strong> " + nama + "<br>" +
    "<strong>Jenis Hari:</strong> " + tLabel + (info.namaHoliday ? " — " + info.namaHoliday : "") + "<br>" +
    "<strong>Tanggal:</strong> " + state.tglFmt + "<br>" +
    "<strong>Jam Masuk:</strong> " + jam + "<br>" +
    "<strong>Jumlah Tiket:</strong> " + state.qty + " orang x " + fmt(state.price) + "<br>" +
    "<strong>Pembayaran:</strong> " + pay + "<br>" +
    "<strong>No. HP:</strong> " + hp + "<br>" +
    "<strong>Total Bayar:</strong> " + fmt(total);
  document.getElementById("bookDetail").innerHTML = detail;
  document.getElementById("modalOverlay").classList.add("show");
}

function closeModal() {
  document.getElementById("modalOverlay").classList.remove("show");
}

document.getElementById("visitDate").min = new Date().toISOString().split("T")[0];
updateSummary();
