<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Waterboom Situsari Garut - Booking Tiket</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --sky:#29B6F6; --sky-dark:#0288D1; --sky-deep:#01579B;
  --sky-light:#B3E5FC; --sky-pale:#E1F5FE; --white:#FFFFFF;
  --off-white:#F0F9FF; --accent:#FF6D00; --text-dark:#01579B;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Poppins',sans-serif;background:var(--off-white);color:var(--text-dark);min-height:100vh;overflow-x:hidden;}

.bg-sky{position:fixed;inset:0;z-index:0;pointer-events:none;
  background:linear-gradient(180deg,#E1F5FE 0%,#B3E5FC 40%,#E1F5FE 100%);}

.wave-deco{position:fixed;bottom:0;left:0;right:0;z-index:0;pointer-events:none;}
.wave-deco svg{width:200%;animation:wavego 12s linear infinite;opacity:.25;}
.wave-deco svg:nth-child(2){animation-delay:-6s;opacity:.15;}
@keyframes wavego{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

header{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.95);
  border-bottom:3px solid var(--sky);backdrop-filter:blur(14px);
  box-shadow:0 2px 20px rgba(41,182,246,.2);}
.header-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;
  justify-content:space-between;padding:.7rem 2rem;gap:1rem;}
.logo-img{height:62px;width:auto;object-fit:contain;}
.header-right{display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;}
.badge-open{background:linear-gradient(135deg,#00C853,#00a846);padding:.35rem .9rem;
  border-radius:20px;font-size:.72rem;font-weight:700;letter-spacing:1px;
  display:flex;align-items:center;gap:.4rem;color:white;
  animation:glow-green 2s ease-in-out infinite;}
@keyframes glow-green{0%,100%{box-shadow:0 0 0 0 rgba(0,200,83,.4)}50%{box-shadow:0 0 0 8px rgba(0,200,83,0)}}
.badge-wa{background:linear-gradient(135deg,#25D366,#128C7E);padding:.35rem .9rem;
  border-radius:20px;font-size:.72rem;font-weight:700;
  display:flex;align-items:center;gap:.4rem;text-decoration:none;color:white;}

.hero{position:relative;z-index:10;min-height:540px;display:flex;flex-direction:column;
  align-items:center;justify-content:center;text-align:center;padding:4rem 2rem 3rem;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:url('data:image/jpeg;base64,') center/cover no-repeat;
  filter:brightness(.45) saturate(.8);}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,
  rgba(2,136,209,.55) 0%,rgba(1,87,155,.8) 60%,rgba(1,87,155,.97) 100%);}
.hero-content{position:relative;z-index:2;max-width:780px;}
.hero-badge{display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(255,255,255,.15);border:1.5px solid rgba(255,255,255,.5);
  border-radius:30px;padding:.4rem 1.2rem;font-size:.78rem;font-weight:700;
  color:white;letter-spacing:2px;text-transform:uppercase;margin-bottom:1rem;
  backdrop-filter:blur(8px);animation:fadeUp .6s ease both;}
.hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.2rem,10vw,7rem);
  letter-spacing:5px;line-height:.9;color:white;
  text-shadow:0 4px 30px rgba(41,182,246,.6);margin-bottom:.6rem;
  animation:fadeUp .6s .1s ease both;opacity:0;animation-fill-mode:forwards;}
.hero-title span{color:var(--sky-light);}
.hero-sub{font-size:1rem;color:rgba(179,229,252,.9);font-weight:500;margin-bottom:2rem;
  animation:fadeUp .6s .2s ease both;opacity:0;animation-fill-mode:forwards;}
.hero-prices{display:flex;gap:1.2rem;justify-content:center;flex-wrap:wrap;
  animation:fadeUp .6s .3s ease both;opacity:0;animation-fill-mode:forwards;}
.price-pill{background:rgba(255,255,255,.12);border:2px solid rgba(255,255,255,.5);
  border-radius:18px;padding:.9rem 1.6rem;text-align:center;backdrop-filter:blur(12px);transition:all .3s;}
.price-pill:hover{background:rgba(255,255,255,.22);transform:translateY(-3px);}
.price-pill .day{font-size:.68rem;font-weight:700;color:var(--sky-light);letter-spacing:2px;text-transform:uppercase;}
.price-pill .amt{font-family:'Bebas Neue',sans-serif;font-size:2.3rem;letter-spacing:2px;color:white;line-height:1;}
.price-pill .sub{font-size:.65rem;color:rgba(179,229,252,.75);}
.price-pill.green .amt{color:#B9F6CA;}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

.info-bar{position:relative;z-index:10;
  background:linear-gradient(135deg,var(--sky-dark),var(--sky-deep));
  padding:1.4rem 2rem;box-shadow:0 4px 20px rgba(2,136,209,.3);}
.info-bar-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;}
.info-item{text-align:center;padding:.4rem;}
.info-icon{font-size:1.7rem;margin-bottom:.25rem;}
.info-label{font-size:.66rem;color:var(--sky-light);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:.15rem;}
.info-val{font-weight:800;font-size:.9rem;color:white;line-height:1.3;}

.gallery-section{position:relative;z-index:10;max-width:1200px;margin:0 auto;padding:3rem 2rem;}
.sec-title{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:3px;
  color:var(--sky-dark);margin-bottom:1.4rem;display:flex;align-items:center;gap:1rem;}
.sec-title::after{content:'';flex:1;height:3px;background:linear-gradient(90deg,var(--sky),transparent);border-radius:2px;}
.gallery-grid{display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:200px 200px;
  gap:10px;border-radius:22px;overflow:hidden;box-shadow:0 8px 40px rgba(2,136,209,.2);}
.gal-item{overflow:hidden;}
.gal-item img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease;display:block;}
.gal-item:hover img{transform:scale(1.07);}
.gal-item:first-child{grid-row:1/3;}

.booking-section{position:relative;z-index:10;max-width:1200px;margin:0 auto;
  padding:2rem 2rem 5rem;display:grid;grid-template-columns:1fr 360px;gap:2rem;}
.left-col{display:flex;flex-direction:column;gap:1.5rem;}

.form-card{background:white;border:1.5px solid var(--sky-pale);border-radius:24px;
  padding:1.8rem;box-shadow:0 4px 24px rgba(41,182,246,.12);}
.form-sec-title{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:2px;
  color:var(--sky-dark);margin-bottom:1.2rem;padding-bottom:.75rem;
  border-bottom:2px solid var(--sky-pale);display:flex;align-items:center;gap:.5rem;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.2rem;}
.form-group{display:flex;flex-direction:column;gap:.35rem;}
.form-group.full{grid-column:1/-1;}
.form-label{font-size:.72rem;font-weight:700;color:var(--sky-dark);letter-spacing:1px;text-transform:uppercase;}
.form-input{background:var(--sky-pale);border:1.5px solid var(--sky-light);border-radius:12px;
  padding:.75rem 1rem;color:var(--sky-deep);font-family:'Poppins',sans-serif;
  font-size:.9rem;font-weight:600;outline:none;transition:all .2s;width:100%;}
.form-input:focus{border-color:var(--sky);background:white;box-shadow:0 0 0 3px rgba(41,182,246,.15);}
.form-input option{background:white;color:var(--sky-deep);}
input[type=date]::-webkit-calendar-picker-indicator{
  filter:invert(39%) sepia(93%) saturate(600%) hue-rotate(178deg);cursor:pointer;}

/* DATE RESULT BOX */
.date-result-box{display:flex;align-items:center;gap:1rem;border-radius:18px;
  padding:1.2rem 1.5rem;margin-top:1rem;border:2.5px solid;
  transition:all .4s ease;position:relative;overflow:hidden;}
.date-result-box.empty{background:var(--sky-pale);border-color:var(--sky-light);}
.date-result-box.weekday{background:linear-gradient(135deg,#E8F5E9,#F0FFF4);border-color:#81C784;}
.date-result-box.weekend{background:linear-gradient(135deg,#FFF8E1,#FFFDE7);border-color:#FFD54F;}
.date-result-box.libur{background:linear-gradient(135deg,#FFF3E0,#FBE9E7);border-color:#FF8A65;}
.drb-icon{font-size:2.5rem;flex-shrink:0;}
.drb-info{flex:1;}
.drb-type{font-family:'Bebas Neue',sans-serif;font-size:1.25rem;letter-spacing:2px;line-height:1;margin-bottom:.2rem;color:var(--sky-deep);}
.date-result-box.weekday .drb-type{color:#2E7D32;}
.date-result-box.weekend .drb-type{color:#F57F17;}
.date-result-box.libur .drb-type{color:#BF360C;}
.drb-desc{font-size:.76rem;color:#546E7A;line-height:1.4;}
.drb-price{text-align:right;flex-shrink:0;}
.drb-price .plabel{font-size:.62rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#78909C;}
.drb-price .amount{font-family:'Bebas Neue',sans-serif;font-size:2.1rem;letter-spacing:1px;line-height:1;}
.drb-price .amount.weekday{color:#2E7D32;}
.drb-price .amount.weekend{color:#F57F17;}
.drb-price .amount.libur{color:#BF360C;}
.drb-badge{position:absolute;top:10px;right:10px;font-size:.6rem;font-weight:800;
  letter-spacing:1px;padding:.2rem .6rem;border-radius:10px;text-transform:uppercase;}
.badge-weekday{background:#C8E6C9;color:#2E7D32;}
.badge-weekend{background:#FFF9C4;color:#F57F17;border:1px solid #FFD54F;}
.badge-libur{background:#FFE0B2;color:#BF360C;border:1px solid #FFAB91;}
.holiday-note{font-size:.7rem;margin-top:.5rem;font-style:italic;font-weight:600;}

.qty-row{display:flex;align-items:center;justify-content:space-between;
  background:var(--sky-pale);border:1.5px solid var(--sky-light);border-radius:14px;padding:.8rem 1.2rem;}
.qty-label{font-weight:700;font-size:.9rem;color:var(--sky-deep);}
.qty-ctrl{display:flex;align-items:center;gap:.75rem;}
.qty-btn{width:36px;height:36px;border-radius:50%;border:2px solid var(--sky);
  background:white;color:var(--sky);font-size:1.3rem;font-weight:900;
  cursor:pointer;transition:all .2s;display:grid;place-items:center;}
.qty-btn:hover{background:var(--sky);color:white;}
.qty-val{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;min-width:36px;text-align:center;color:var(--sky-deep);}

.notice{background:#FFF3E0;border:1.5px solid #FFCC80;border-radius:14px;
  padding:.9rem 1.1rem;font-size:.78rem;color:#E65100;line-height:1.6;
  display:flex;gap:.6rem;margin-bottom:1.2rem;}

.summary-wrap{display:flex;flex-direction:column;gap:1.5rem;}
.summary-card{background:linear-gradient(160deg,var(--sky-dark) 0%,var(--sky-deep) 100%);
  border:none;border-radius:24px;padding:1.8rem;position:sticky;top:90px;
  box-shadow:0 8px 40px rgba(2,136,209,.35);}
.sum-title{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:2px;
  color:white;margin-bottom:1.2rem;padding-bottom:.75rem;border-bottom:1.5px solid rgba(255,255,255,.2);}
.sum-row{display:flex;justify-content:space-between;align-items:flex-start;padding:.4rem 0;font-size:.82rem;}
.sum-row .lbl{color:var(--sky-light);flex-shrink:0;margin-right:.5rem;}
.sum-row .val{font-weight:700;text-align:right;color:white;}
.sum-row.highlight-price .val{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;
  letter-spacing:1px;padding:2px 8px;border-radius:8px;}
.sum-row.highlight-price.weekday .val{color:#B9F6CA;background:rgba(0,200,83,.2);}
.sum-row.highlight-price.weekend .val{color:#FFD600;background:rgba(255,214,0,.2);}
.sum-row.highlight-price.libur .val{color:#FFAB91;background:rgba(255,140,0,.2);}
.sum-divider{border:none;border-top:1px dashed rgba(255,255,255,.2);margin:.75rem 0;}
.sum-total{display:flex;justify-content:space-between;align-items:center;padding:.75rem 0 0;}
.sum-total .lbl{font-weight:800;font-size:1rem;color:var(--sky-light);}
.sum-total .val{font-family:'Bebas Neue',sans-serif;font-size:2.4rem;color:white;letter-spacing:1px;}

.btn-book{width:100%;margin-top:1.2rem;padding:1.1rem;
  background:linear-gradient(135deg,#FF6D00,#FF8F00);color:white;border:none;
  border-radius:16px;font-family:'Bebas Neue',sans-serif;font-size:1.4rem;
  letter-spacing:2px;cursor:pointer;transition:all .3s;
  box-shadow:0 6px 25px rgba(255,109,0,.4);position:relative;overflow:hidden;}
.btn-book::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.25),transparent);transition:left .5s;}
.btn-book:hover::before{left:100%;}
.btn-book:hover{transform:translateY(-2px);box-shadow:0 10px 35px rgba(255,109,0,.5);}

.fac-section{position:relative;z-index:10;max-width:1200px;margin:0 auto;padding:0 2rem 4rem;}
.fac-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1rem;}
.fac-card{background:white;border:1.5px solid var(--sky-light);border-radius:18px;
  padding:1.2rem 1rem;text-align:center;transition:all .25s;
  box-shadow:0 2px 12px rgba(41,182,246,.08);}
.fac-card:hover{border-color:var(--sky);transform:translateY(-3px);box-shadow:0 6px 24px rgba(41,182,246,.2);}
.fac-icon{font-size:2rem;margin-bottom:.4rem;}
.fac-name{font-size:.8rem;font-weight:700;color:var(--sky-dark);}

.modal-overlay{position:fixed;inset:0;background:rgba(1,87,155,.8);z-index:1000;
  display:flex;align-items:center;justify-content:center;padding:1rem;
  opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(10px);}
.modal-overlay.show{opacity:1;pointer-events:all;}
.modal{background:white;border:3px solid var(--sky);border-radius:28px;padding:2.5rem;
  max-width:500px;width:100%;text-align:center;transform:scale(.9);transition:transform .3s;
  box-shadow:0 20px 60px rgba(2,136,209,.3);}
.modal-overlay.show .modal{transform:scale(1);}
.modal-icon{font-size:4rem;margin-bottom:1rem;animation:pop .5s ease both;}
@keyframes pop{from{transform:scale(0) rotate(-20deg)}to{transform:scale(1) rotate(0)}}
.modal h2{font-family:'Bebas Neue',sans-serif;font-size:2.5rem;letter-spacing:3px;color:var(--sky-dark);margin-bottom:.5rem;}
.modal p{color:#546E7A;font-size:.9rem;line-height:1.6;margin-bottom:1.2rem;}
.modal-code{background:var(--sky-pale);border:2.5px dashed var(--sky);border-radius:14px;
  padding:1rem;font-family:'Bebas Neue',sans-serif;font-size:2.2rem;
  letter-spacing:6px;margin-bottom:1.2rem;color:var(--sky-deep);}
.modal-detail{background:var(--sky-pale);border-radius:12px;padding:1rem;
  font-size:.82rem;color:#37474F;line-height:1.8;margin-bottom:1.5rem;text-align:left;}
.modal-detail strong{color:var(--sky-dark);}
.btn-close{background:linear-gradient(135deg,var(--sky),var(--sky-dark));color:white;
  border:none;border-radius:12px;padding:.8rem 2rem;font-family:'Bebas Neue',sans-serif;
  font-size:1.2rem;letter-spacing:2px;cursor:pointer;
  box-shadow:0 4px 15px rgba(41,182,246,.4);transition:opacity .2s;}
.btn-close:hover{opacity:.85;}

footer{position:relative;z-index:10;
  background:linear-gradient(135deg,var(--sky-dark),var(--sky-deep));
  padding:2.5rem 2rem;text-align:center;}
.footer-inner{max-width:1200px;margin:0 auto;}
.footer-logo{height:65px;margin-bottom:1rem;}
.footer-info{font-size:.78rem;color:var(--sky-light);line-height:1.9;}
.footer-social{display:flex;gap:.75rem;justify-content:center;margin:1rem 0;flex-wrap:wrap;}
.social-btn{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);
  border-radius:10px;padding:.4rem .9rem;font-size:.75rem;font-weight:700;
  color:white;text-decoration:none;transition:all .2s;display:flex;align-items:center;gap:.4rem;}
.social-btn:hover{background:rgba(255,255,255,.3);}

@media(max-width:900px){
  .booking-section{grid-template-columns:1fr;}
  .info-bar-inner{grid-template-columns:repeat(2,1fr);}
  .gallery-grid{grid-template-columns:1fr 1fr;grid-template-rows:auto;}
  .gal-item:first-child{grid-row:auto;}
  .summary-card{position:static;}
  .form-grid{grid-template-columns:1fr;}
}
@media(max-width:600px){
  .header-inner{padding:.6rem 1rem;}
  .hero{padding:2.5rem 1rem 2rem;min-height:420px;}
  .info-bar-inner{grid-template-columns:1fr 1fr;}
  .booking-section,.gallery-section,.fac-section{padding-left:1rem;padding-right:1rem;}
}
</style>
</head>
<body>

<div class="bg-sky"></div>
<div class="wave-deco">
  <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg"><path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,30 1440,40 L1440,80 L0,80Z" fill="#29B6F6"/></svg>
  <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg"><path d="M0,55 C240,20 480,70 720,45 C960,20 1200,65 1440,45 L1440,80 L0,80Z" fill="#0288D1"/></svg>
</div>

<header>
  <div class="header-inner">
    <img src="data:image/png;base64," alt="Waterboom Situsari" class="logo-img">
    <div class="header-right">
      <div class="badge-open">🟢 BUKA SETIAP HARI</div>
      <a href="https://wa.me/6287782482284" target="_blank" class="badge-wa">💬 WhatsApp Admin</a>
      <a href="/admin" style="background:var(--sky-pale);color:var(--sky-dark);border:1.5px solid var(--sky-light);border-radius:20px;padding:.35rem .9rem;font-size:.72rem;font-weight:700;text-decoration:none;">🔒 Admin</a>
    </div>
  </div>
</header>

<div class="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-badge">🎢 Waterboom Situsari Garut</div>
    <div class="hero-title">SERUNYA<br><span>TIADA HENTI</span></div>
    <div class="hero-sub">📍 Jl. Cigangsa, Desa Situsari, Kec. Cisuruan, Kab. Garut 44163</div>
    <div class="hero-prices">
      <div class="price-pill"><div class="day">Weekday</div><div class="amt">Rp 15.000</div><div class="sub">Senin – Jumat</div></div>
      <div class="price-pill"><div class="day">Weekend / Libur</div><div class="amt">Rp 20.000</div><div class="sub">Sabtu, Minggu & Hari Libur</div></div>
      <div class="price-pill green"><div class="day">Usia &lt; 2 Tahun</div><div class="amt">GRATIS</div><div class="sub">Tinggi &lt; 80 cm</div></div>
    </div>
  </div>
</div>

<div class="info-bar">
  <div class="info-bar-inner">
    <div class="info-item"><div class="info-icon">🕐</div><div class="info-label">Jam Operasional</div><div class="info-val">08.00 – 17.00 WIB</div></div>
    <div class="info-item"><div class="info-icon">📅</div><div class="info-label">Buka</div><div class="info-val">Senin – Minggu<br><small style="font-size:.7rem;color:#B3E5FC">Jum'at: 13.00 – 17.00</small></div></div>
    <div class="info-item"><div class="info-icon">📏</div><div class="info-label">Syarat Tiket</div><div class="info-val">Usia &ge; 2 Tahun<br><small style="font-size:.7rem;color:#B3E5FC">Tinggi &ge; 80 cm</small></div></div>
    <div class="info-item"><div class="info-icon">📞</div><div class="info-label">Kontak Admin</div><div class="info-val">0877-8248-2284</div></div>
  </div>
</div>

<div class="gallery-section">
  <div class="sec-title">📸 GALERI WATERBOOM</div>
  <div class="gallery-grid">
    <div class="gal-item"><img src="data:image/jpeg;base64," alt="Kolam Utama"></div>
    <div class="gal-item"><img src="data:image/jpeg;base64," alt="Wahana Anak"></div>
    <div class="gal-item"><img src="data:image/jpeg;base64," alt="Seluncuran"></div>
    <div class="gal-item"><img src="data:image/jpeg;base64," alt="Kolam Arus"></div>
    <div class="gal-item"><img src="data:image/jpeg;base64," alt="Kolam Air Hangat"></div>
  </div>
</div>

<div class="booking-section">
  <div class="left-col">
    <div class="form-card">
      <div class="form-sec-title">📅 PILIH TANGGAL KUNJUNGAN</div>
      <div class="form-group" style="margin-bottom:.5rem;">
        <label class="form-label">Tanggal Kunjungan *</label>
        <input class="form-input" type="date" id="visitDate" onchange="onDateChange()">
      </div>
      <div class="date-result-box empty" id="dateResultBox">
        <div class="drb-icon" id="drbIcon">📅</div>
        <div class="drb-info">
          <div class="drb-type" id="drbType" style="color:#90A4AE;">Pilih tanggal kunjungan</div>
          <div class="drb-desc" id="drbDesc">Harga tiket akan otomatis menyesuaikan hari yang dipilih</div>
        </div>
        <div class="drb-price" id="drbPriceBox" style="display:none;">
          <div class="plabel">HARGA/TIKET</div>
          <div class="amount" id="drbAmount">—</div>
        </div>
